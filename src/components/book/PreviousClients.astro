---
// PreviousClients.astro — Previous Clients & Events section for the Book Us page
// Requirement 9.8: at least 3 entries, each displayed as a text name card
---

<section class="py-16 bg-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <h2 class="font-serif text-3xl md:text-4xl text-navy text-center mb-12">
      Previous Clients &amp; Events
    </h2>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">

      <!-- Birmingham Town Hall -->
      <div class="bg-cream border border-gold/30 rounded-lg p-4">
        <p class="font-bold text-navy text-lg mb-1">Birmingham Town Hall</p>
        <p class="text-gray-700">Christmas Concert 2024 — A sold-out festive celebration for 400+ guests</p>
      </div>

      <!-- Cannon Hill Park World Music Festival -->
      <div class="bg-cream border border-gold/30 rounded-lg p-4">
        <p class="font-bold text-navy text-lg mb-1">Cannon Hill Park World Music Festival</p>
        <p class="text-gray-700">Summer Festival 2024 — Open-air performance for 1,200+ festival-goers</p>
      </div>

      <!-- University of Birmingham -->
      <div class="bg-cream border border-gold/30 rounded-lg p-4">
        <p class="font-bold text-navy text-lg mb-1">University of Birmingham</p>
        <p class="text-gray-700">Graduation Ceremony 2023 — Ceremonial performance for graduating students and families</p>
      </div>

      <!-- St Philip's Cathedral, Birmingham -->
      <div class="bg-cream border border-gold/30 rounded-lg p-4">
        <p class="font-bold text-navy text-lg mb-1">St Philip's Cathedral, Birmingham</p>
        <p class="text-gray-700">Easter Concert 2023 — Sacred music performance for the local congregation</p>
      </div>

    </div>
  </div>
</section>
