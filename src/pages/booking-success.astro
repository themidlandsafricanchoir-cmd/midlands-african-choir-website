---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Booking Enquiry Submitted | T-MAC UK"
  description="Thank you for your booking enquiry."
  canonicalPath="/booking-success"
>
  <section class="bg-black min-h-[70vh] flex items-center justify-center px-4">
    <div class="max-w-xl text-center">
      <span class="text-6xl block mb-6">✅</span>
      <h1 class="font-serif text-3xl md:text-4xl text-gold mb-4">Thank You!</h1>
      <p class="text-cream/80 text-lg leading-relaxed mb-8">
        Thank you for contacting T-MAC UK. We have received your booking enquiry and will respond as soon as possible.
      </p>
      <a href="/" class="inline-block bg-gold text-black font-bold px-8 py-3 rounded hover:bg-gold/90 transition-colors min-h-[44px]">
        Back to Home
      </a>
    </div>
  </section>
</BaseLayout>
