---
import BaseLayout from '../layouts/BaseLayout.astro';
import SectionHero from '../components/shared/SectionHero.astro';
import PatternDivider from '../components/shared/PatternDivider.astro';
---

<BaseLayout
  title="Book T-MAC UK | The Midlands African Choir"
  description="Book The Midlands African Choir UK for your event, wedding, festival, church service, corporate function, or community celebration."
  canonicalPath="/book"
>

  <!-- ── HERO ─────────────────────────────────────────────── -->
  <SectionHero
    title="Book T-MAC UK"
    subtitle="Bring the vibrant sounds of African choral music to your event, celebration, festival, church service, corporate function, fundraiser, or community gathering."
    backgroundImage="/images/placeholders/Book-us.jpg"
  />

  <!-- CTA buttons below hero -->
  <section class="bg-black py-8 px-4 text-center">
    <div class="flex flex-col sm:flex-row gap-4 justify-center">
      <a href="#booking-form" class="bg-gold text-black font-bold px-8 py-3 rounded min-h-[44px] inline-flex items-center justify-center hover:bg-gold/90 transition-colors">
        Submit Booking Enquiry
      </a>
      <a href="#contact" class="border-2 border-white text-white font-bold px-8 py-3 rounded min-h-[44px] inline-flex items-center justify-center hover:bg-white hover:text-black transition-colors">
        Contact Us
      </a>
    </div>
  </section>

  <PatternDivider />

  <!-- ── SECTION 1: EVENTS WE PERFORM AT ──────────────────── -->
  <section class="bg-black py-16 px-4">
    <div class="max-w-6xl mx-auto">
      <div class="text-center mb-12">
        <h2 class="font-serif text-3xl md:text-4xl text-gold mb-4">Events We Perform At</h2>
        <p class="text-cream/60 text-lg max-w-2xl mx-auto">From intimate gatherings to large-scale festivals, T-MAC UK brings energy, culture, and unforgettable music to every occasion.</p>
      </div>

      <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
        {[
          { icon: '🎪', title: 'Festivals', desc: 'Music, cultural and community festivals' },
          { icon: '💍', title: 'Weddings', desc: 'Ceremony and reception performances' },
          { icon: '⛪', title: 'Church Services', desc: 'Sunday services, thanksgiving and praise nights' },
          { icon: '🏢', title: 'Corporate Events', desc: 'Conferences, galas and staff celebrations' },
          { icon: '🎉', title: 'Community Celebrations', desc: 'Local gatherings, heritage days and parties' },
          { icon: '🌍', title: 'Cultural Events', desc: 'Black History Month, Africa Day and more' },
          { icon: '❤️', title: 'Charity Fundraisers', desc: 'Benefit concerts and awareness events' },
          { icon: '🎶', title: 'Private Functions', desc: 'Birthdays, anniversaries and special occasions' },
        ].map(card => (
          <div class="border border-gold/20 rounded-xl p-5 text-center hover:border-gold/50 transition-colors group">
            <span class="text-3xl block mb-3" aria-hidden="true">{card.icon}</span>
            <h3 class="font-serif text-sm md:text-base text-gold mb-1 group-hover:text-gold">{card.title}</h3>
            <p class="text-cream/40 text-xs leading-relaxed">{card.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <PatternDivider variant="adinkra" />

  <!-- ── SECTION 2: WHY CHOOSE T-MAC UK ───────────────────── -->
  <section class="bg-black py-16 px-4">
    <div class="max-w-5xl mx-auto">
      <div class="text-center mb-12">
        <h2 class="font-serif text-3xl md:text-4xl text-gold mb-4">Why Choose T-MAC UK</h2>
      </div>

      <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-6">
        {[
          { icon: '🎵', heading: 'Authentic African Choral Music', text: 'Rooted in the rich musical traditions of Africa — gospel, highlife, folk and contemporary arrangements that move and inspire.' },
          { icon: '🎼', heading: 'Diverse Repertoire', text: 'We perform in multiple African languages and styles, tailoring our set list to suit the mood and audience of your event.' },
          { icon: '⭐', heading: 'Professional & Reliable', text: 'Punctual, well-rehearsed and fully self-sufficient. We arrive prepared and deliver every time.' },
          { icon: '🌟', heading: 'Cultural Excellence', text: 'More than music — we bring the spirit of Ubuntu, cultural pride, and community connection to every performance.' },
        ].map(card => (
          <div class="border border-gold/20 rounded-xl p-6 hover:border-gold/50 transition-colors">
            <span class="text-3xl block mb-4" aria-hidden="true">{card.icon}</span>
            <h3 class="font-serif text-lg text-gold mb-3">{card.heading}</h3>
            <p class="text-cream/60 text-sm leading-relaxed">{card.text}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <PatternDivider />

  <!-- ── SECTION 3: BOOKING ENQUIRY FORM (Netlify Forms) ──── -->
  <section id="booking-form" class="bg-black py-16 px-4">
    <div class="max-w-2xl mx-auto">
      <div class="text-center mb-10">
        <h2 class="font-serif text-3xl md:text-4xl text-gold mb-4">Booking Enquiry</h2>
        <p class="text-cream/60 text-lg">Tell us about your event and we'll get back to you as soon as possible.</p>
      </div>

      <form
        name="booking"
        method="POST"
        data-netlify="true"
        netlify-honeypot="bot-field"
        action="/booking-success"
        class="space-y-5"
      >
        <!-- Netlify hidden fields -->
        <input type="hidden" name="form-name" value="booking" />
        <p class="hidden">
          <label>Don't fill this out: <input name="bot-field" /></label>
        </p>

        <!-- Full Name -->
        <div>
          <label for="name" class="block text-cream/80 text-sm font-medium mb-1">Full Name <span class="text-gold">*</span></label>
          <input type="text" id="name" name="name" required class="w-full bg-white/5 border border-gold/20 rounded-lg px-4 py-3 text-cream placeholder-cream/30 focus:outline-none focus:border-gold focus:ring-1 focus:ring-gold" placeholder="Your full name" />
        </div>

        <!-- Email -->
        <div>
          <label for="email" class="block text-cream/80 text-sm font-medium mb-1">Email Address <span class="text-gold">*</span></label>
          <input type="email" id="email" name="email" required class="w-full bg-white/5 border border-gold/20 rounded-lg px-4 py-3 text-cream placeholder-cream/30 focus:outline-none focus:border-gold focus:ring-1 focus:ring-gold" placeholder="you@example.com" />
        </div>

        <!-- Phone -->
        <div>
          <label for="phone" class="block text-cream/80 text-sm font-medium mb-1">Phone Number <span class="text-gold">*</span></label>
          <input type="tel" id="phone" name="phone" required class="w-full bg-white/5 border border-gold/20 rounded-lg px-4 py-3 text-cream placeholder-cream/30 focus:outline-none focus:border-gold focus:ring-1 focus:ring-gold" placeholder="07xxx xxx xxx" />
        </div>

        <!-- Organisation (optional) -->
        <div>
          <label for="organisation" class="block text-cream/80 text-sm font-medium mb-1">Organisation Name <span class="text-cream/40">(optional)</span></label>
          <input type="text" id="organisation" name="organisation" class="w-full bg-white/5 border border-gold/20 rounded-lg px-4 py-3 text-cream placeholder-cream/30 focus:outline-none focus:border-gold focus:ring-1 focus:ring-gold" placeholder="Your organisation" />
        </div>

        <!-- Event Type -->
        <div>
          <label for="event-type" class="block text-cream/80 text-sm font-medium mb-1">Event Type <span class="text-gold">*</span></label>
          <select id="event-type" name="event-type" required class="w-full bg-white/5 border border-gold/20 rounded-lg px-4 py-3 text-cream focus:outline-none focus:border-gold focus:ring-1 focus:ring-gold">
            <option value="" disabled selected>Select event type</option>
            <option value="Festival">Festival</option>
            <option value="Wedding">Wedding</option>
            <option value="Church Service">Church Service</option>
            <option value="Corporate Event">Corporate Event</option>
            <option value="Community Celebration">Community Celebration</option>
            <option value="Cultural Event">Cultural Event</option>
            <option value="Charity Fundraiser">Charity Fundraiser</option>
            <option value="Private Function">Private Function</option>
            <option value="Other">Other</option>
          </select>
        </div>

        <!-- Event Date -->
        <div>
          <label for="event-date" class="block text-cream/80 text-sm font-medium mb-1">Event Date <span class="text-gold">*</span></label>
          <input type="date" id="event-date" name="event-date" required class="w-full bg-white/5 border border-gold/20 rounded-lg px-4 py-3 text-cream focus:outline-none focus:border-gold focus:ring-1 focus:ring-gold" />
        </div>

        <!-- Venue / Location -->
        <div>
          <label for="venue" class="block text-cream/80 text-sm font-medium mb-1">Venue / Location <span class="text-gold">*</span></label>
          <input type="text" id="venue" name="venue" required class="w-full bg-white/5 border border-gold/20 rounded-lg px-4 py-3 text-cream placeholder-cream/30 focus:outline-none focus:border-gold focus:ring-1 focus:ring-gold" placeholder="Venue name and city" />
        </div>

        <!-- Audience Size (optional) -->
        <div>
          <label for="audience-size" class="block text-cream/80 text-sm font-medium mb-1">Expected Audience Size <span class="text-cream/40">(optional)</span></label>
          <select id="audience-size" name="audience-size" class="w-full bg-white/5 border border-gold/20 rounded-lg px-4 py-3 text-cream focus:outline-none focus:border-gold focus:ring-1 focus:ring-gold">
            <option value="" selected>Select size</option>
            <option value="Under 50">Under 50</option>
            <option value="50-200">50–200</option>
            <option value="200-500">200–500</option>
            <option value="500+">500+</option>
          </select>
        </div>

        <!-- Message -->
        <div>
          <label for="message" class="block text-cream/80 text-sm font-medium mb-1">Message <span class="text-gold">*</span></label>
          <textarea id="message" name="message" rows="4" required class="w-full bg-white/5 border border-gold/20 rounded-lg px-4 py-3 text-cream placeholder-cream/30 focus:outline-none focus:border-gold focus:ring-1 focus:ring-gold resize-y" placeholder="Tell us about your event and any specific requirements..."></textarea>
        </div>

        <!-- Submit -->
        <div class="pt-2">
          <button type="submit" class="w-full bg-gold text-black font-bold py-4 rounded-lg hover:bg-gold/90 transition-colors min-h-[44px] text-lg">
            Submit Booking Enquiry
          </button>
        </div>
      </form>
    </div>
  </section>

  <PatternDivider variant="adinkra" />

  <!-- ── SECTION 4: CONTACT INFORMATION ───────────────────── -->
  <section id="contact" class="bg-black py-16 px-4">
    <div class="max-w-3xl mx-auto text-center">
      <h2 class="font-serif text-3xl md:text-4xl text-gold mb-8">Contact Us Directly</h2>

      <div class="grid sm:grid-cols-3 gap-6 mb-8">
        <div class="border border-gold/20 rounded-xl p-6">
          <span class="text-2xl block mb-2" aria-hidden="true">📧</span>
          <p class="text-cream/50 text-xs uppercase tracking-wide mb-1">Email</p>
          <a href="mailto:themidlandsafricanchoir@gmail.com" class="text-gold text-sm hover:underline break-all">themidlandsafricanchoir@gmail.com</a>
        </div>
        <div class="border border-gold/20 rounded-xl p-6">
          <span class="text-2xl block mb-2" aria-hidden="true">📱</span>
          <p class="text-cream/50 text-xs uppercase tracking-wide mb-1">Phone</p>
          <a href="tel:07597698854" class="text-gold text-sm hover:underline">075 976 98854</a>
        </div>
        <div class="border border-gold/20 rounded-xl p-6">
          <span class="text-2xl block mb-2" aria-hidden="true">🌐</span>
          <p class="text-cream/50 text-xs uppercase tracking-wide mb-1">Social Media</p>
          <div class="flex justify-center gap-3 mt-2">
            <a href="https://www.tiktok.com/@themidlandsafricanchoir" target="_blank" rel="noopener noreferrer" class="text-cream/60 hover:text-gold text-xs">TikTok</a>
            <a href="https://www.facebook.com/share/1BdrZZvhP6/" target="_blank" rel="noopener noreferrer" class="text-cream/60 hover:text-gold text-xs">Facebook</a>
            <a href="https://www.instagram.com/themidlandsafricanchoir" target="_blank" rel="noopener noreferrer" class="text-cream/60 hover:text-gold text-xs">Instagram</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <PatternDivider />

  <!-- ── SECTION 5: FAQ ───────────────────────────────────── -->
  <section class="bg-black py-16 px-4">
    <div class="max-w-3xl mx-auto">
      <h2 class="font-serif text-3xl md:text-4xl text-gold mb-10 text-center">Frequently Asked Questions</h2>

      <div class="space-y-4">
        {[
          { q: 'How far do you travel?', a: 'We are based in the Midlands and primarily perform within a 60-mile radius. However, we are happy to discuss events further afield depending on logistics and availability.' },
          { q: 'Do you perform outside the Midlands?', a: 'Yes — for the right event we will travel nationally. Please get in touch with details of your location and we will let you know if we can accommodate.' },
          { q: 'How much does a performance cost?', a: 'Our fees vary depending on the type of event, duration of performance, location, and any travel requirements. Contact us with your event details for a quote.' },
          { q: 'How much notice do you require?', a: 'We recommend at least 4–6 weeks notice to allow for rehearsal and preparation. However, please still get in touch for shorter-notice requests and we will do our best.' },
          { q: 'Can you perform specific songs?', a: 'We have a growing repertoire of African choral music, gospel, and contemporary arrangements. We are happy to discuss song requests and can often learn new pieces for special occasions.' },
        ].map((faq, i) => (
          <details class="group border border-gold/20 rounded-xl overflow-hidden">
            <summary class="flex items-center justify-between p-5 cursor-pointer hover:bg-gold/5 transition-colors">
              <span class="text-cream/90 font-medium text-sm pr-4">{faq.q}</span>
              <svg class="w-5 h-5 text-gold/50 flex-shrink-0 transform group-open:rotate-180 transition-transform" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                <path fill-rule="evenodd" d="M5.293 7.293a1 1 0 011.414 0L10 10.586l3.293-3.293a1 1 0 111.414 1.414l-4 4a1 1 0 01-1.414 0l-4-4a1 1 0 010-1.414z" clip-rule="evenodd" />
              </svg>
            </summary>
            <div class="px-5 pb-5 text-cream/60 text-sm leading-relaxed border-t border-gold/10 pt-4">
              {faq.a}
            </div>
          </details>
        ))}
      </div>
    </div>
  </section>

</BaseLayout>
