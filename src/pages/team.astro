---
import { getCollection } from 'astro:content';

import BaseLayout from '../layouts/BaseLayout.astro';
import SectionHero from '../components/shared/SectionHero.astro';
import TeamCard from '../components/team/TeamCard.astro';

const team = await getCollection('team');

const sortedTeam = team.sort((a, b) => {
  if (a.data.order !== b.data.order) {
    return a.data.order - b.data.order;
  }

  return a.data.name.localeCompare(b.data.name);
});
---

<BaseLayout
  title="Meet the Team | T-MAC UK"
  description="Meet the talented singers and leaders of The Midlands African Choir UK."
  canonicalPath="/team"
>
  <SectionHero
    title="Meet the Team"
    subtitle="The voices behind The Midlands African Choir UK"
    backgroundImage="/images/placeholders/meet-team-1536x1024.jpg"
    heightClass="h-[40vh] md:h-[50vh]"
    objectPosition="object-cover object-center"
  />

  <section class="py-16 px-4 bg-white">
    <div class="max-w-7xl mx-auto">
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
        {
          sortedTeam.map((member) => (
            <TeamCard
              name={member.data.name}
              role={member.data.role}
              bio={member.data.bio}
              image={member.data.image}
              lightBg={true}
            />
          ))
        }
      </div>
    </div>
  </section>
</BaseLayout>
